# Copy this file to .env and fill in real values before running locally or deploying.

# A long, random string. Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Leave unset to use local SQLite. On a host like Render/Railway, set this to
# the Postgres connection string they give you.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated emails allowed to approve club officer claims
ADMIN_EMAILS=demo@uw.edu

# Set to "false" to allow any email address to register (useful outside UW)
REQUIRE_EDU_EMAIL=true

FLASK_DEBUG=false
PORT=5050
